// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum Locale {
  ar
  en
}

// REMOVED Currency enum to avoid migration issues

enum ShowOfferType {
  CODE
  DEAL
  DISCOUNT
  FREE_SHIPPING
  CASHBACK
  OFFER
}

enum VoucherType {
  CODE           // Requires coupon code
  DEAL           // Auto-applied deal
  FREE_SHIPPING  // Free shipping offer
}

enum PromoType {
  BANK_OFFER      // "15% off with SABB"
  CARD_OFFER      // "Extra 10% with Visa"
  PAYMENT_OFFER   // "5% cashback via STC Pay"
  SEASONAL        // "Ramadan Special"
  BUNDLE          // "Buy 2 Get 1 Free"
  OTHER
}

enum DiscountType {
  PERCENTAGE
  ABSOLUTE
}

enum CuratedOfferType {
  CODE           // Requires coupon code
  DEAL           // Auto-applied deal
  PRODUCT        // Specific product discount
  SEASONAL       // Seasonal offer (Ramadan, Black Friday, etc)
  FREE_SHIPPING  // Free shipping offer
  CASHBACK       // Cashback reward
  BUNDLE         // Buy X Get Y
  FLASH_SALE     // Limited time flash sale
}

enum PaymentType {
  CARD
  BNPL
  COD
  WALLET
  BANK_TRANSFER
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

// Blog status lifecycle
enum BlogStatus {
  DRAFT      // Being written, not visible publicly
  PUBLISHED  // Live and visible
  ARCHIVED   // Hidden but preserved
}

// Content type — drives template selection and structured data
enum BlogContentType {
  GUIDE        // How-to, tips — informational evergreen
  DEAL_HUB     // Aggregated deals page for one merchant or category
  SEASONAL     // Ramadan, Black Friday, Back to School, etc.
  COMPARISON   // Store A vs Store B, product comparisons
  NEWS         // Time-sensitive announcements
}

// Search intent — used for internal link strategy + schema.org type
enum SearchIntent {
  INFORMATIONAL   // "how to save money on noon"
  COMMERCIAL      // "best noon deals right now"
  TRANSACTIONAL   // "noon coupon code"
}

// Leaderboard / savings snapshot
enum RankMovement {
  UP    // Rose in rank vs previous week
  DOWN  // Dropped in rank vs previous week
  SAME  // No change
  NEW   // No previous snapshot exists
}

// Stackability groups
enum OfferStackGroup {
  DEAL         // Auto-applied site-wide discount
  CODE         // Requires a coupon code
  BANK_OFFER   // Bank / card / payment method offer
  CASHBACK     // Post-purchase return — not a point-of-sale % saving
  BUNDLE       // Buy X get Y — excluded from % calculator
}

// Discount certainty (affects multiplier applied)
enum DiscountCertainty {
  EXACT      // "10% off everything" — applies to every purchase, no conditions
  VERIFIED   // Admin has manually checked real product prices and entered a true average
  TYPICAL    // Admin researched the store; figure is a reasonable estimate
  ESTIMATED  // "Up to X% off" marketing claim — headline figure, not typical saving
  UNKNOWN    // No reliable number available
}

// Confidence level for store intelligence predictions
enum ConfidenceLevel {
  LOW     // Based on general industry patterns
  MEDIUM  // Based on this store's historical behaviour
  HIGH    // Admin has confirmed or store has announced
}

// === NEW BANK ENUMS ===
enum BankType {
  COMMERCIAL
  ISLAMIC
  DIGITAL
}

enum CardNetwork {
  VISA
  MASTERCARD
  MADA
  AMEX
  UNIONPAY
}

enum CardTier {
  CLASSIC
  GOLD
  PLATINUM
  SIGNATURE
  INFINITE
  WORLD_ELITE
}

// ============================================================================
// CORE MODELS
// ============================================================================

model Country {
  id        Int      @id @default(autoincrement())
  code      String   @unique // SA, EG, AE
  currency  String   // SAR, EGP, AED - KEPT AS STRING to avoid migration
  flag      String?  // 🇸🇦
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)

  translations        CountryTranslation[]
  stores              StoreCountry[]
  vouchers            VoucherCountry[]
  faqs                StoreFAQ[]
  storePayments       StorePaymentMethod[]
  voucherClicks       VoucherClick[]
  storeProductClicks  StoreProductClick[]
  otherPromos         OtherPromo[]
  curatedOffers       CuratedOfferCountry[]
  storeProducts       StoreProductCountry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model CountryTranslation {
  id        Int    @id @default(autoincrement())
  countryId Int
  locale    Locale

  name String

  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, locale])
  @@index([locale])
}

// ============================================================================
// STORE - ENHANCED WITH COVER IMAGE AND INTELLIGENCE FIELDS
// ============================================================================

model Store {
  id Int @id @default(autoincrement())

  // Images
  logo            String?
  bigLogo         String?
  backgroundImage String?
  coverImage      String? // Hero banner for store page
  color           String? // Brand color for UI theming

  showOfferType ShowOfferType?

  // URLs
  websiteUrl       String
  affiliateNetwork String?
  trackingUrl      String?

  // Status
  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)

  // ── Logistics & returns (store intelligence) ───────────────────────────
  averageDeliveryDaysMin  Int?      // e.g. 1 (fastest quoted delivery)
  averageDeliveryDaysMax  Int?      // e.g. 5 (slowest quoted delivery)
  freeShippingThreshold   Float?    // SAR. null = always paid. 0 = always free.
  returnWindowDays        Int?      // How many days to initiate a return
  freeReturns             Boolean   @default(false)
  refundProcessingDaysMin Int?      // Shortest quoted refund time
  refundProcessingDaysMax Int?      // Longest quoted refund time
  offerFrequencyDays      Int?      // Average days between major promotions
  lastVerifiedAt          DateTime? // When admin last verified logistics info

  // Relations
  translations   StoreTranslation[]
  countries      StoreCountry[]
  vouchers       Voucher[]
  categories     StoreCategory[]
  faqs           StoreFAQ[]
  paymentMethods StorePaymentMethod[]
  otherPromos    OtherPromo[]
  products       StoreProduct[]
  curatedOffers  CuratedOffer[]
  // Blog relations
  primaryBlogPosts    BlogPost[]         @relation("PrimaryStore")
  blogPostStores      BlogPostStore[]
  blogSectionStores   BlogPostSectionStore[]
  // Leaderboard snapshots
  savingsSnapshots    StoreSavingsSnapshot[]
  // Store intelligence
  savingsMetrics      StoreSavingsMetrics[]
  upcomingEvents      StoreUpcomingEvent[]
  peakSeasons         StorePeakSeason[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([isFeatured])
  @@index([showOfferType])
}

model StoreTranslation {
  id      Int    @id @default(autoincrement())
  storeId Int
  locale  Locale

  name        String
  slug        String
  description String? @db.Text

  // SEO
  seoTitle       String?
  seoDescription String? @db.Text

  showOffer String? // "Get 15% off all orders" / "خصم 15% على جميع الطلبات"

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, locale])
  @@unique([locale, slug])
  @@index([locale])
  @@index([slug])
}

// ============================================================================
// CATEGORY - ENHANCED WITH IMAGE AND BANK SCORING WEIGHTS
// ============================================================================

model Category {
  id    Int     @id @default(autoincrement())
  icon  String? // Material icon name (e.g., "checkroom", "devices")
  image String? // Category banner/thumbnail
  color String? // Category accent color

  // Bank niche scoring (null = not a bank scoring category)
  bankScoringWeights Json? // JSON object with weights for criteria (e.g., {"loungeAccess": 0.2, "cashbackGeneral": 0.5})

  translations CategoryTranslation[]
  stores       StoreCategory[]
  savingsSnapshots StoreSavingsSnapshot[] // for category leaderboards

  // Bank niche snapshots (leaderboard rows for this category)
  bankNicheSnapshots BankNicheSnapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([color])
}

model CategoryTranslation {
  id         Int    @id @default(autoincrement())
  categoryId Int
  locale     Locale

  name        String
  slug        String
  description String? @db.Text

  seoTitle       String?
  seoDescription String? @db.Text

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@unique([locale, slug])
  @@index([locale])
  @@index([slug])
}

// ============================================================================
// VOUCHER - COUPONS & DEALS (with stackability & certainty fields)
// ============================================================================

model Voucher {
  id      Int @id @default(autoincrement())
  storeId Int

  // Voucher Details
  code     String?     // Coupon code (e.g., "SAVE20")
  type     VoucherType
  discount String?     // "20%", "50 SAR off", "Buy 1 Get 1"

  // Numeric fields for calculation
  discountPercent    Float?               // Numeric headline %
  verifiedAvgPercent Float?               // Admin-verified true average (overrides discountPercent)
  discountCertainty  DiscountCertainty    @default(ESTIMATED)
  stackGroup         OfferStackGroup      @default(DEAL)
  isStackable        Boolean              @default(false)
  isCapped           Boolean              @default(false)
  maxDiscountAmount  Float?               // SAR ceiling
  minSpendAmount     Float?               // SAR minimum basket
  isFeaturedStack    Boolean  @default(false)

  // Image for featured deals
  image String? // Hero image for visual deals

  // Links
  landingUrl String? // Direct product/deal URL

  // Validity
  startDate  DateTime?
  expiryDate DateTime?

  // Badges
  isExclusive Boolean @default(false)
  isVerified  Boolean @default(false)

  // Analytics
  popularityScore Int @default(0)
  clickCount      Int @default(0)

  // Relations
  translations VoucherTranslation[]
  countries    VoucherCountry[]
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  clicks       VoucherClick[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([expiryDate])
  @@index([isExclusive])
  @@index([isVerified])
  @@index([popularityScore])
  @@index([clickCount])
  @@index([type])
}

model VoucherTranslation {
  id        Int    @id @default(autoincrement())
  voucherId Int
  locale    Locale

  title       String        // "20% Off Everything"
  description String? @db.Text // "Valid on all items. Min spend 200 SAR"

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@unique([voucherId, locale])
  @@index([locale])
}

// ============================================================================
// STORE PRODUCTS - FEATURED ITEMS
// ============================================================================

model StoreProduct {
  id      Int @id @default(autoincrement())
  storeId Int

  // Product Details
  image        String       // Product image (required)
  discountValue Float?       // Discount amount (percentage or absolute)
  discountType  DiscountType @default(PERCENTAGE)

  // Links
  productUrl String // Direct link to product on store website

  // Display
  isFeatured Boolean @default(true) // Show on store page
  order      Int     @default(0)    // Display order

  // Analytics
  clickCount Int @default(0)

  // Relations
  translations StoreProductTranslation[]
  store        Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  clicks       StoreProductClick[]
  countries    StoreProductCountry[]
  blogProducts BlogPostProduct[]        // post-level product links
  blogSectionProducts BlogPostSectionProduct[] // section-level product links

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([isFeatured])
  @@index([order])
  @@index([discountType])
}

model StoreProductTranslation {
  id        Int    @id @default(autoincrement())
  productId Int
  locale    Locale

  title       String        // Changed from optional to required
  description String? @db.Text

  product StoreProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@index([locale])
}

model StoreProductClick {
  id        Int  @id @default(autoincrement())
  productId Int
  countryId Int?

  ipHash    String?
  userAgent String?
  referrer  String?
  clickedAt DateTime @default(now())

  product StoreProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  country Country?     @relation(fields: [countryId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([clickedAt])
  @@index([countryId])
}

// ============================================================================
// OTHER PROMOS - BANK/CARD OFFERS (with stackability & certainty fields, and bank relations)
// ============================================================================

model OtherPromo {
  id        Int @id @default(autoincrement())
  storeId   Int
  countryId Int

  // Promo Details
  image String?    // Banner image
  type  PromoType

  // Numeric fields for calculation
  discountPercent    Float?               // Numeric headline %
  verifiedAvgPercent Float?               // Admin-verified true average
  discountCertainty  DiscountCertainty    @default(EXACT) // bank offers are contract terms
  stackGroup         OfferStackGroup      @default(BANK_OFFER)
  isStackable        Boolean              @default(false)
  isCapped           Boolean              @default(false)
  maxDiscountAmount  Float?               // SAR ceiling
  minSpendAmount     Float?               // SAR minimum basket

  // Links
  url String? // External link to T&Cs or signup

  // Validity
  startDate  DateTime?
  expiryDate DateTime?

  isActive Boolean @default(true)
  order    Int     @default(0)

  // Bank-related fields (new)
  bankId            Int?
  cardId            Int?
  cardNetwork       CardNetwork?
  installmentMonths Int?

  // Relations
  translations OtherPromoTranslation[]
  store        Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  country      Country @relation(fields: [countryId], references: [id], onDelete: Cascade)
  bank         Bank?     @relation(fields: [bankId], references: [id], onDelete: SetNull)
  card         BankCard? @relation(fields: [cardId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, countryId])
  @@index([isActive])
  @@index([expiryDate])
  @@index([order])
  @@index([type])
  @@index([bankId])
  @@index([cardId])
}

model OtherPromoTranslation {
  id      Int    @id @default(autoincrement())
  promoId Int
  locale  Locale

  title       String        // "10% Cashback with Visa"
  description String? @db.Text
  terms       String? @db.Text

  promo OtherPromo @relation(fields: [promoId], references: [id], onDelete: Cascade)

  @@unique([promoId, locale])
  @@index([locale])
}

// ============================================================================
// CURATED OFFERS - ENHANCED WITH COUNTRY RELATION
// ============================================================================

model CuratedOffer {
  id      Int @id @default(autoincrement())
  storeId Int

  // Offer Details
  offerImage String           // Squircle image URL
  code       String?          // Optional coupon code
  type       CuratedOfferType

  // CTA
  ctaUrl String // Where clicking leads

  // Validity
  startDate  DateTime?
  expiryDate DateTime?

  // Display
  isFeatured Boolean @default(false)
  isActive   Boolean @default(true)
  order      Int     @default(0)

  // Relations
  translations CuratedOfferTranslation[]
  store        Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  countries    CuratedOfferCountry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([isFeatured])
  @@index([isActive])
  @@index([expiryDate])
  @@index([type])
  @@index([order])
}

model CuratedOfferTranslation {
  id      Int    @id @default(autoincrement())
  offerId Int
  locale  Locale

  title       String        // "€25 BYOD Plan!"
  description String? @db.Text
  ctaText     String        // "SHOP NOW", "GET OFFER"

  offer CuratedOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([offerId, locale])
  @@index([locale])
}

// ============================================================================
// PAYMENT METHODS
// ============================================================================

model PaymentMethod {
  id     Int         @id @default(autoincrement())
  slug   String      @unique
  type   PaymentType
  isBnpl Boolean     @default(false)
  logo   String?

  translations PaymentMethodTranslation[]
  storeLinks   StorePaymentMethod[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isBnpl])
  @@index([slug])
}

model PaymentMethodTranslation {
  id              Int    @id @default(autoincrement())
  paymentMethodId Int
  locale          Locale

  name        String
  description String? @db.Text

  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)

  @@unique([paymentMethodId, locale])
  @@index([locale])
}

model StorePaymentMethod {
  id              Int @id @default(autoincrement())
  storeId         Int
  countryId       Int
  paymentMethodId Int

  isActive  Boolean @default(true)
  minAmount Float?
  maxAmount Float?

  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  country       Country       @relation(fields: [countryId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)
  translations  StorePaymentMethodTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, countryId, paymentMethodId])
  @@index([storeId, countryId])
  @@index([isActive])
}

model StorePaymentMethodTranslation {
  id                   Int    @id @default(autoincrement())
  storePaymentMethodId Int
  locale               Locale

  notes String? @db.Text

  storePaymentMethod StorePaymentMethod @relation(fields: [storePaymentMethodId], references: [id], onDelete: Cascade)

  @@unique([storePaymentMethodId, locale])
  @@index([locale])
}

// ============================================================================
// STORE FAQ
// ============================================================================

model StoreFAQ {
  id        Int     @id @default(autoincrement())
  storeId   Int
  countryId Int
  order     Int     @default(0)
  isActive  Boolean @default(true)

  translations StoreFAQTranslation[]
  store        Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  country      Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, countryId, order])
  @@index([storeId, countryId])
  @@index([isActive])
  @@index([order])
}

model StoreFAQTranslation {
  id     Int    @id @default(autoincrement())
  faqId  Int
  locale Locale

  question String
  answer   String @db.Text

  faq StoreFAQ @relation(fields: [faqId], references: [id], onDelete: Cascade)

  @@unique([faqId, locale])
  @@index([locale])
}

// ============================================================================
// JUNCTION TABLES
// ============================================================================

model StoreCountry {
  storeId   Int
  countryId Int

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@id([storeId, countryId])
}

model VoucherCountry {
  voucherId Int
  countryId Int

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@id([voucherId, countryId])
}

model StoreCategory {
  storeId    Int
  categoryId Int

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([storeId, categoryId])
}

model CuratedOfferCountry {
  offerId   Int
  countryId Int

  offer   CuratedOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  country Country      @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@id([offerId, countryId])
}

model StoreProductCountry {
  productId Int
  countryId Int

  product StoreProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  country Country      @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@id([productId, countryId])
}

// ============================================================================
// ANALYTICS
// ============================================================================

model VoucherClick {
  id        Int  @id @default(autoincrement())
  voucherId Int
  countryId Int?

  ipHash    String?
  userAgent String?
  referrer  String?
  clickedAt DateTime @default(now())

  voucher Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  country Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)

  @@index([voucherId])
  @@index([clickedAt])
  @@index([countryId])
}

// ============================================================================
// ADMIN
// ============================================================================

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  password     String
  role         AdminRole @default(ADMIN)
  permissions  String[]
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  resetToken   String?
  resetExpires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([isActive])
}

// ============================================================================
// BLOG SYSTEM
// ============================================================================

// ── Author ───────────────────────────────────────────────────────────────────

model BlogAuthor {
  id            Int     @id @default(autoincrement())
  name          String  // Display name in English
  nameAr        String? // Display name in Arabic
  avatar        String? // URL to profile photo
  bio           String? @db.Text // Short bio in English
  bioAr         String? @db.Text // Short bio in Arabic
  twitterHandle String? // Without @, used for schema.org sameAs

  posts BlogPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

// ── Blog Category ─────────────────────────────────────────────────────────────

model BlogCategory {
  id    Int     @id @default(autoincrement())
  slug  String  @unique // e.g. "shopping-tips" — shared across locales
  color String? // Accent color for UI badges
  icon  String? // Optional icon name

  translations BlogCategoryTranslation[]
  posts        BlogPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model BlogCategoryTranslation {
  id          Int    @id @default(autoincrement())
  categoryId  Int
  locale      Locale // Uses existing Locale enum (ar | en)

  name        String
  description String? @db.Text

  category BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@index([locale])
}

// ── Blog Tag ──────────────────────────────────────────────────────────────────

model BlogTag {
  id   Int    @id @default(autoincrement())
  slug String @unique // e.g. "noon", "electronics"

  translations BlogTagTranslation[]
  posts        BlogPostTag[]

  createdAt DateTime @default(now())

  @@index([slug])
}

model BlogTagTranslation {
  id     Int    @id @default(autoincrement())
  tagId  Int
  locale Locale

  name String // e.g. "Electronics" / "إلكترونيات"

  tag BlogTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, locale])
  @@index([locale])
}

// ── Blog Post ─────────────────────────────────────────────────────────────────

model BlogPost {
  id            Int              @id @default(autoincrement())
  slug          String           @unique
  featuredImage String?

  // ── Status & visibility ───────────────────────────────────────────────────
  isFeatured  Boolean    @default(false)
  status      BlogStatus @default(DRAFT)
  publishedAt DateTime?

  // ── SEO strategy fields ───────────────────────────────────────────────────
  contentType   BlogContentType @default(GUIDE)
  searchIntent  SearchIntent    @default(INFORMATIONAL)
  readingTime   Int?            // minutes, computed from content word count
  faqJson       String?         @db.Text // JSON array: [{q, a}, ...] for FAQ schema.org

  // ── Merchant clustering ───────────────────────────────────────────────────
  primaryStoreId Int?
  primaryStore   Store? @relation("PrimaryStore", fields: [primaryStoreId], references: [id], onDelete: SetNull)

  // ── Taxonomy ──────────────────────────────────────────────────────────────
  authorId   Int?
  categoryId Int?
  author     BlogAuthor?   @relation(fields: [authorId], references: [id], onDelete: SetNull)
  category   BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // ── Relations ─────────────────────────────────────────────────────────────
  translations     BlogPostTranslation[]
  tags             BlogPostTag[]
  sections         BlogPostSection[]     // structured content blocks
  linkedStores     BlogPostStore[]       // explicit post-level store links
  relatedProducts  BlogPostProduct[]     // post-level product links
  relatedPosts     BlogPostRelated[] @relation("PostToRelated")
  relatedTo        BlogPostRelated[] @relation("RelatedToPost")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([contentType])
  @@index([searchIntent])
  @@index([primaryStoreId])
  @@index([isFeatured])
  @@index([categoryId])
  @@index([authorId])
  @@index([slug])
}

model BlogPostTranslation {
  id     Int    @id @default(autoincrement())
  postId Int
  locale Locale

  title   String
  excerpt String  @db.Text // Short summary for cards and meta
  content String  @db.Text // Full HTML/rich text body

  metaTitle       String?
  metaDescription String? @db.Text

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, locale])
  @@index([locale])
}

model BlogPostTag {
  postId Int
  tagId  Int

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model BlogPostProduct {
  postId    Int
  productId Int

  post    BlogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  product StoreProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([postId, productId])
}

model BlogPostRelated {
  postId        Int
  relatedPostId Int
  order         Int @default(0)

  post        BlogPost @relation("PostToRelated", fields: [postId], references: [id], onDelete: Cascade)
  relatedPost BlogPost @relation("RelatedToPost", fields: [relatedPostId], references: [id], onDelete: Cascade)

  @@id([postId, relatedPostId])
  @@index([postId, order])
}

model BlogPostStore {
  postId  Int
  storeId Int
  order   Int @default(0)

  post  BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  store Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([postId, storeId])
  @@index([postId, order])
  @@index([storeId])
}

model BlogPostSection {
  id     Int @id @default(autoincrement())
  postId Int
  order  Int @default(0)

  image String?

  post         BlogPost                    @relation(fields: [postId], references: [id], onDelete: Cascade)
  translations BlogPostSectionTranslation[]
  products     BlogPostSectionProduct[]
  stores       BlogPostSectionStore[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, order])
}

model BlogPostSectionTranslation {
  id        Int    @id @default(autoincrement())
  sectionId Int
  locale    Locale

  subtitle String?        // Optional section heading (h3)
  content  String @db.Text // Section body — HTML/rich text

  section BlogPostSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, locale])
  @@index([locale])
}

model BlogPostSectionProduct {
  sectionId Int
  productId Int
  order     Int @default(0)

  section BlogPostSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  product StoreProduct    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([sectionId, productId])
  @@index([sectionId, order])
}

model BlogPostSectionStore {
  sectionId Int
  storeId   Int
  order     Int @default(0)

  section BlogPostSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  store   Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([sectionId, storeId])
  @@index([sectionId, order])
}

// ============================================================================
// LEADERBOARD (SAVINGS SNAPSHOTS)
// ============================================================================

model SavingsMethodology {
  id          Int     @id @default(autoincrement())
  version     String  @unique   // e.g. "v1", "v2"
  description String  @db.Text  // Plain-language formula description
  isActive    Boolean @default(false) // Only one row should be true at a time

  // Formula parameters stored as config
  maxSavingsCap       Float @default(75.0)  // Absolute ceiling (%)
  bankOfferStackable  Boolean @default(true) // Whether bank offers stack
  couponStackable     Boolean @default(true) // Whether coupons stack on top of deals
  referenceBasketSize Float @default(500.0) // SAR basket size used to compute effective % for capped offers
  multiplierExact     Float @default(1.00)
  multiplierVerified  Float @default(1.00)
  multiplierTypical   Float @default(0.80)
  multiplierEstimated Float @default(0.35)

  snapshots StoreSavingsSnapshot[]

  createdAt DateTime @default(now())

  @@index([isActive])
}

model StoreSavingsSnapshot {
  id        Int    @id @default(autoincrement())
  storeId   Int
  categoryId Int?               // NULL = global leaderboard; set = category leaderboard

  // Raw component scores (stored for auditability)
  maxDirectDiscountPercent Float @default(0) // Best active DEAL voucher
  maxCouponPercent         Float @default(0) // Best active CODE voucher
  maxBankOfferPercent      Float @default(0) // Best active bank/card promo

  // Calculated output
  calculatedMaxSavingsPercent Float    // Final stacked % after formula + cap
  savingsOverridePercent      Float?   // Admin can pin a manual value; NULL = use calculated
  stackingPath                String?  // e.g. "DEAL(20.0%) + BANK_OFFER(12.0%)"

  // Ranking
  rank         Int             // 1 = best this week
  previousRank Int?            // NULL if NEW entry
  movement     RankMovement @default(NEW)

  // Traceability
  weekIdentifier     String  // ISO week: "2026-W10"
  methodologyId      Int?    // Which formula version produced this row
  calculatedAt       DateTime @default(now())

  // Relations
  store       Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category    Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  methodology SavingsMethodology? @relation(fields: [methodologyId], references: [id], onDelete: SetNull)

  // One snapshot per store+category+week (idempotent upsert)
  @@unique([storeId, categoryId, weekIdentifier])

  @@index([weekIdentifier, rank])
  @@index([storeId, weekIdentifier])
  @@index([categoryId, weekIdentifier, rank])
  @@index([movement])
}

// ============================================================================
// STORE INTELLIGENCE
// ============================================================================

model StoreSavingsMetrics {
  id              Int    @id @default(autoincrement())
  storeId         Int
  monthIdentifier String // "2026-03" — ISO year-month

  // Savings data (inputs to score)
  averageDiscountPercent    Float @default(0) // Mean across all active offers
  maxStackableSavingsPercent Float @default(0) // Best compound saving (from leaderboard cron)
  codeSuccessRate           Float @default(0) // 0–100: % of code clicks that weren't "code invalid"
  totalActiveOffers         Int   @default(0) // Count of non-expired vouchers + promos
  offerQualityRatio         Float @default(0) // Added field

  // Pre-computed score (avoids recalculating on every request)
  storeScore      Float @default(0) // 0–10 scale, stored after cron calculates it
  scoreBreakdown  String? @db.Text  // JSON: { savings: 2.7, codeSuccess: 1.6, ... }

  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, monthIdentifier])
  @@index([storeId, monthIdentifier])
  @@index([monthIdentifier])
}

model StoreUpcomingEvent {
  id              Int            @id @default(autoincrement())
  storeId         Int
  eventName       String         // e.g. "Ramadan Sale", "White Friday"
  expectedMonth   String         // "2026-03" — ISO year-month
  confidenceLevel ConfidenceLevel @default(MEDIUM)
  expectedMaxDiscount Float?     // Optional: what % off is typically expected
  notes           String?        @db.Text

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([expectedMonth])
  @@index([confidenceLevel])
}

model StorePeakSeason {
  id        Int    @id @default(autoincrement())
  storeId   Int
  seasonKey String // Stable key: "ramadan", "white_friday", "back_to_school", etc.
  nameEn    String // "Ramadan Sale"
  nameAr    String // "تخفيضات رمضان"

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, seasonKey])
  @@index([storeId])
  @@index([seasonKey])
}

// ============================================================================
// NEW BANK MODELS
// ============================================================================

model Bank {
  id         Int      @id @default(autoincrement())
  slug       String   @unique
  logo       String?
  color      String?
  websiteUrl String?
  type       BankType @default(COMMERCIAL)
  appRating  Float?
  isActive   Boolean  @default(true)

  translations   BankTranslation[]
  cards          BankCard[]
  nicheSnapshots BankNicheSnapshot[]
  otherPromos    OtherPromo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([type])
}

model BankTranslation {
  id     Int    @id @default(autoincrement())
  bankId Int
  locale Locale

  name        String
  description String? @db.Text

  bank Bank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@unique([bankId, locale])
  @@index([locale])
}

model BankCard {
  id        Int  @id @default(autoincrement())
  bankId    Int

  network   CardNetwork
  tier      CardTier    @default(CLASSIC)
  isIslamic Boolean     @default(false)
  image     String?

  // Financials
  annualFee           Float?
  minSalary           Float?
  foreignTxFeePercent Float?

  // Perks
  loungeAccessPerYear   Int?
  hasTravelInsurance    Boolean @default(false)
  hasPurchaseProtection Boolean @default(false)
  hasApplePay           Boolean @default(true)
  hasGooglePay          Boolean @default(true)
  hasSamsungPay         Boolean @default(false)

  // Earn rates (%) per spend category — feed the scoring engine
  cashbackGeneral    Float?
  cashbackTravel     Float?
  cashbackDining     Float?
  cashbackShopping   Float?
  cashbackFuel       Float?
  cashbackGaming     Float?
  cashbackGroceries  Float?
  cashbackOnline     Float?
  cashbackHealthcare Float?

  maxInstallmentMonths Int?

  bank         Bank                @relation(fields: [bankId], references: [id], onDelete: Cascade)
  translations BankCardTranslation[]
  otherPromos  OtherPromo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bankId])
  @@index([network])
  @@index([tier])
}

model BankCardTranslation {
  id     Int    @id @default(autoincrement())
  cardId Int
  locale Locale

  name        String
  description String? @db.Text
  benefits    String? @db.Text

  card BankCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, locale])
  @@index([locale])
}

// Weekly auto-calculated leaderboard row, one per bank × category (niche)
model BankNicheSnapshot {
  id         Int @id @default(autoincrement())
  bankId     Int
  categoryId Int   // reuses Category (travel, gaming, dining…)

  weekIdentifier String   // "2026-W10"

  score          Float         // 0–100 normalised
  rank           Int
  previousRank   Int?
  movement       RankMovement  @default(NEW) // reuses existing enum

  // Per-criterion breakdown for radar chart: { "loungeAccess": 8.5, ... }
  scoreBreakdown Json

  bestCardId Int?  // which of the bank's cards drove this score

  bank     Bank     @relation(fields: [bankId],     references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  calculatedAt DateTime @default(now())

  @@unique([bankId, categoryId, weekIdentifier])
  @@index([categoryId, weekIdentifier, rank])
  @@index([bankId])
}

// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum Locale {
  ar
  en
}

enum ShowOfferType {
  CODE
  DEAL
  DISCOUNT
  FREE_SHIPPING
  CASHBACK
  OFFER
}

enum VoucherType {
  CODE
  DEAL
  FREE_SHIPPING
}

enum PromoType {
  BANK_OFFER
  CARD_OFFER
  PAYMENT_OFFER
  SEASONAL
  BUNDLE
  OTHER
}

enum DiscountType {
  PERCENTAGE
  ABSOLUTE
}

enum CuratedOfferType {
  CODE
  DEAL
  PRODUCT
  SEASONAL
  FREE_SHIPPING
  CASHBACK
  BUNDLE
  FLASH_SALE
}

enum PaymentType {
  CARD
  BNPL
  COD
  WALLET
  BANK_TRANSFER
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum BlogContentType {
  GUIDE
  DEAL_HUB
  SEASONAL
  COMPARISON
  NEWS
}

enum SearchIntent {
  INFORMATIONAL
  COMMERCIAL
  TRANSACTIONAL
}

enum RankMovement {
  UP
  DOWN
  SAME
  NEW
}

enum OfferStackGroup {
  DEAL
  CODE
  BANK_OFFER
  CASHBACK
  BUNDLE
}

enum DiscountCertainty {
  EXACT
  VERIFIED
  TYPICAL
  ESTIMATED
  UNKNOWN
}

enum ConfidenceLevel {
  LOW
  MEDIUM
  HIGH
}

// Bank enums
enum BankType {
  COMMERCIAL
  ISLAMIC
  DIGITAL
}

enum CardNetwork {
  VISA
  MASTERCARD
  MADA
  AMEX
  UNIONPAY
}

enum CardTier {
  CLASSIC
  GOLD
  PLATINUM
  SIGNATURE
  INFINITE
  WORLD_ELITE
}

// NEW COMPARISON TABLE ENUMS
enum ComparisonEntityType {
  STORE
  BANK
  BANK_CARD
  VOUCHER
  PROMO
  PRODUCT
  CUSTOM
}

enum ComparisonRowType {
  TEXT
  RATING
  BOOLEAN
  BADGE
}

enum SectionBlockType {
  TEXT
  POST
  TABLE
  PRODUCT
  STORE
  BANK
  CARD
}

// ============================================================================
// CORE MODELS
// ============================================================================

model Country {
  id        Int      @id @default(autoincrement())
  code      String   @unique
  currency  String
  flag      String?
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)

  translations        CountryTranslation[]
  stores              StoreCountry[]
  vouchers            VoucherCountry[]
  faqs                StoreFAQ[]
  storePayments       StorePaymentMethod[]
  voucherClicks       VoucherClick[]
  storeProductClicks  StoreProductClick[]
  otherPromos         OtherPromo[]
  curatedOffers       CuratedOfferCountry[]
  storeProducts       StoreProductCountry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model CountryTranslation {
  id        Int    @id @default(autoincrement())
  countryId Int
  locale    Locale

  name String

  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, locale])
  @@index([locale])
}

// ============================================================================
// STORE
// ============================================================================

model Store {
  id Int @id @default(autoincrement())

  logo            String?
  bigLogo         String?
  backgroundImage String?
  coverImage      String?
  color           String?

  showOfferType ShowOfferType?

  websiteUrl       String
  affiliateNetwork String?
  trackingUrl      String?

  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)

  averageDeliveryDaysMin  Int?
  averageDeliveryDaysMax  Int?
  freeShippingThreshold   Float?
  returnWindowDays        Int?
  freeReturns             Boolean   @default(false)
  refundProcessingDaysMin Int?
  refundProcessingDaysMax Int?
  offerFrequencyDays      Int?
  lastVerifiedAt          DateTime?

  translations   StoreTranslation[]
  countries      StoreCountry[]
  vouchers       Voucher[]
  categories     StoreCategory[]
  faqs           StoreFAQ[]
  paymentMethods StorePaymentMethod[]
  otherPromos    OtherPromo[]
  products       StoreProduct[]
  curatedOffers  CuratedOffer[]

  primaryBlogPosts    BlogPost[]         @relation("PrimaryStore")
  blogPostStores      BlogPostStore[]
  blogSectionStores   BlogPostSectionStore[]

  savingsSnapshots    StoreSavingsSnapshot[]
  savingsMetrics      StoreSavingsMetrics[]
  upcomingEvents      StoreUpcomingEvent[]
  peakSeasons         StorePeakSeason[]
  offerStacks         OfferStack[]

  // NEW back‑relation for comparison tables
  comparisonColumns   ComparisonTableColumn[]

  // Section block embeds
  embeddedInSectionBlocks SectionBlock[] @relation("SectionEmbeddedStores")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([isFeatured])
  @@index([showOfferType])
}

model StoreTranslation {
  id      Int    @id @default(autoincrement())
  storeId Int
  locale  Locale

  name        String
  slug        String
  description String? @db.Text

  seoTitle       String?
  seoDescription String? @db.Text
  showOffer      String?

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, locale])
  @@unique([locale, slug])
  @@index([locale])
  @@index([slug])
}

// ============================================================================
// CATEGORY
// ============================================================================

model Category {
  id    Int     @id @default(autoincrement())
  icon  String?
  image String?
  color String?
  order Int     @default(0)   // ← ADD THIS

  bankScoringWeights Json?

  translations CategoryTranslation[]
  stores       StoreCategory[]
  savingsSnapshots StoreSavingsSnapshot[]
  bankNicheSnapshots BankNicheSnapshot[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([color])
}

model CategoryTranslation {
  id         Int    @id @default(autoincrement())
  categoryId Int
  locale     Locale

  name        String
  slug        String
  description String? @db.Text

  seoTitle       String?
  seoDescription String? @db.Text

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@unique([locale, slug])
  @@index([locale])
  @@index([slug])
}

// ============================================================================
// VOUCHER
// ============================================================================

model Voucher {
  id      Int @id @default(autoincrement())
  storeId Int

  code     String?
  type     VoucherType
  discount String?

  discountPercent    Float?
  verifiedAvgPercent Float?
  discountCertainty  DiscountCertainty    @default(ESTIMATED)
  stackGroup         OfferStackGroup      @default(DEAL)
  isStackable        Boolean              @default(false)
  isCapped           Boolean              @default(false)
  maxDiscountAmount  Float?
  minSpendAmount     Float?
  isFeaturedStack    Boolean               @default(false)

  image String?

  landingUrl String?

  startDate  DateTime?
  expiryDate DateTime?

  isExclusive Boolean @default(false)
  isVerified  Boolean @default(false)

  popularityScore Int @default(0)
  clickCount      Int @default(0)

  translations VoucherTranslation[]
  countries    VoucherCountry[]
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  clicks       VoucherClick[]
  stackAsCode  OfferStack[] @relation("StackCode")
  stackAsDeal  OfferStack[] @relation("StackDeal")

  // NEW back‑relation for comparison tables
  comparisonColumns ComparisonTableColumn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([expiryDate])
  @@index([isExclusive])
  @@index([isVerified])
  @@index([popularityScore])
  @@index([clickCount])
  @@index([type])
}

model VoucherTranslation {
  id        Int    @id @default(autoincrement())
  voucherId Int
  locale    Locale

  title       String
  description String? @db.Text

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@unique([voucherId, locale])
  @@index([locale])
}

// ============================================================================
// STORE PRODUCTS
// ============================================================================

model StoreProduct {
  id      Int @id @default(autoincrement())
  storeId Int

  image        String
  discountValue Float?
  discountType  DiscountType @default(PERCENTAGE)

  productUrl String

  isFeatured Boolean @default(true)
  order      Int     @default(0)

  clickCount Int @default(0)

  translations StoreProductTranslation[]
  store        Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  clicks       StoreProductClick[]
  countries    StoreProductCountry[]
  blogProducts BlogPostProduct[]
  blogSectionProducts BlogPostSectionProduct[]

  // NEW back‑relation for comparison tables
  comparisonColumns ComparisonTableColumn[]

  // Section block embeds
  embeddedInSectionBlocks SectionBlock[] @relation("SectionEmbeddedProducts")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([isFeatured])
  @@index([order])
  @@index([discountType])
}

model StoreProductTranslation {
  id        Int    @id @default(autoincrement())
  productId Int
  locale    Locale

  title       String
  description String? @db.Text

  product StoreProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@index([locale])
}

model StoreProductClick {
  id        Int  @id @default(autoincrement())
  productId Int
  countryId Int?

  ipHash    String?
  userAgent String?
  referrer  String?
  clickedAt DateTime @default(now())

  product StoreProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  country Country?     @relation(fields: [countryId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([clickedAt])
  @@index([countryId])
}

// ============================================================================
// OTHER PROMOS
// ============================================================================

model OtherPromo {
  id        Int @id @default(autoincrement())
  storeId   Int
  countryId Int

  image String?
  type  PromoType

  discountPercent    Float?
  verifiedAvgPercent Float?
  discountCertainty  DiscountCertainty @default(EXACT)
  stackGroup         OfferStackGroup   @default(BANK_OFFER)
  isStackable        Boolean           @default(false)
  isCapped           Boolean           @default(false)
  maxDiscountAmount  Float?
  minSpendAmount     Float?

  url String?

  startDate  DateTime?
  expiryDate DateTime?

  isActive Boolean @default(true)
  order    Int     @default(0)

  bankId            Int?
  cardId            Int?
  paymentMethodId   Int?          // ← NEW: Visa, Mastercard, Tabby, Tamara, etc.
  cardNetwork       CardNetwork?
  installmentMonths Int?
  voucherCode       String?

  translations OtherPromoTranslation[]
  store        Store          @relation(fields: [storeId],         references: [id], onDelete: Cascade)
  country      Country        @relation(fields: [countryId],       references: [id], onDelete: Cascade)
  bank         Bank?          @relation(fields: [bankId],          references: [id], onDelete: SetNull)
  card         BankCard?      @relation(fields: [cardId],          references: [id], onDelete: SetNull)
  paymentMethod PaymentMethod? @relation(fields: [paymentMethodId], references: [id], onDelete: SetNull)  // ← NEW
  offerStacks  OfferStack[]   @relation("StackPromo")

  comparisonColumns ComparisonTableColumn[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, countryId])
  @@index([isActive])
  @@index([expiryDate])
  @@index([order])
  @@index([type])
  @@index([bankId])
  @@index([cardId])
  @@index([paymentMethodId])  // ← NEW
}


model OtherPromoTranslation {
  id      Int    @id @default(autoincrement())
  promoId Int
  locale  Locale

  title       String
  description String? @db.Text
  terms       String? @db.Text

  promo OtherPromo @relation(fields: [promoId], references: [id], onDelete: Cascade)

  @@unique([promoId, locale])
  @@index([locale])
}

// ============================================================================
// OFFER STACKS
// ============================================================================

model OfferStack {
  id      Int @id @default(autoincrement())
  storeId Int

  label String?

  codeVoucherId Int?
  dealVoucherId Int?
  promoId       Int?

  isActive Boolean @default(true)
  order    Int     @default(0)

  store       Store       @relation(fields: [storeId],       references: [id], onDelete: Cascade)
  codeVoucher Voucher?    @relation("StackCode",             fields: [codeVoucherId], references: [id], onDelete: SetNull)
  dealVoucher Voucher?    @relation("StackDeal",             fields: [dealVoucherId], references: [id], onDelete: SetNull)
  promo       OtherPromo? @relation("StackPromo",            fields: [promoId],       references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([isActive])
  @@index([order])
}

// ============================================================================
// CURATED OFFERS
// ============================================================================

model CuratedOffer {
  id      Int @id @default(autoincrement())
  storeId Int

  offerImage String
  code       String?
  type       CuratedOfferType

  ctaUrl String

  startDate  DateTime?
  expiryDate DateTime?

  isFeatured Boolean @default(false)
  isActive   Boolean @default(true)
  order      Int     @default(0)

  translations CuratedOfferTranslation[]
  store        Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  countries    CuratedOfferCountry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([isFeatured])
  @@index([isActive])
  @@index([expiryDate])
  @@index([type])
  @@index([order])
}

model CuratedOfferTranslation {
  id      Int    @id @default(autoincrement())
  offerId Int
  locale  Locale

  title       String
  description String? @db.Text
  ctaText     String

  offer CuratedOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([offerId, locale])
  @@index([locale])
}

// ============================================================================
// PAYMENT METHODS
// ============================================================================

model PaymentMethod {
  id     Int         @id @default(autoincrement())
  slug   String      @unique
  type   PaymentType
  isBnpl Boolean     @default(false)
  logo   String?

  translations PaymentMethodTranslation[]
  storeLinks   StorePaymentMethod[]
  otherPromos  OtherPromo[]               // ← NEW back-relation

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isBnpl])
  @@index([slug])
}

model PaymentMethodTranslation {
  id              Int    @id @default(autoincrement())
  paymentMethodId Int
  locale          Locale

  name        String
  description String? @db.Text

  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)

  @@unique([paymentMethodId, locale])
  @@index([locale])
}

model StorePaymentMethod {
  id              Int @id @default(autoincrement())
  storeId         Int
  countryId       Int
  paymentMethodId Int

  isActive  Boolean @default(true)
  minAmount Float?
  maxAmount Float?

  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  country       Country       @relation(fields: [countryId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)
  translations  StorePaymentMethodTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, countryId, paymentMethodId])
  @@index([storeId, countryId])
  @@index([isActive])
}

model StorePaymentMethodTranslation {
  id                   Int    @id @default(autoincrement())
  storePaymentMethodId Int
  locale               Locale

  notes String? @db.Text

  storePaymentMethod StorePaymentMethod @relation(fields: [storePaymentMethodId], references: [id], onDelete: Cascade)

  @@unique([storePaymentMethodId, locale])
  @@index([locale])
}

// ============================================================================
// STORE FAQ
// ============================================================================

model StoreFAQ {
  id        Int     @id @default(autoincrement())
  storeId   Int
  countryId Int
  order     Int     @default(0)
  isActive  Boolean @default(true)

  translations StoreFAQTranslation[]
  store        Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  country      Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, countryId, order])
  @@index([storeId, countryId])
  @@index([isActive])
  @@index([order])
}

model StoreFAQTranslation {
  id     Int    @id @default(autoincrement())
  faqId  Int
  locale Locale

  question String
  answer   String @db.Text

  faq StoreFAQ @relation(fields: [faqId], references: [id], onDelete: Cascade)

  @@unique([faqId, locale])
  @@index([locale])
}

// ============================================================================
// JUNCTION TABLES
// ============================================================================

model StoreCountry {
  storeId   Int
  countryId Int

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@id([storeId, countryId])
}

model VoucherCountry {
  voucherId Int
  countryId Int

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@id([voucherId, countryId])
}

model StoreCategory {
  storeId    Int
  categoryId Int

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([storeId, categoryId])
}

model CuratedOfferCountry {
  offerId   Int
  countryId Int

  offer   CuratedOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  country Country      @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@id([offerId, countryId])
}

model StoreProductCountry {
  productId Int
  countryId Int

  product StoreProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  country Country      @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@id([productId, countryId])
}

// ============================================================================
// ANALYTICS
// ============================================================================

model VoucherClick {
  id        Int  @id @default(autoincrement())
  voucherId Int
  countryId Int?

  ipHash    String?
  userAgent String?
  referrer  String?
  clickedAt DateTime @default(now())

  voucher Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  country Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)

  @@index([voucherId])
  @@index([clickedAt])
  @@index([countryId])
}

// ============================================================================
// ADMIN
// ============================================================================

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  password     String
  role         AdminRole @default(ADMIN)
  permissions  String[]
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  resetToken   String?
  resetExpires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([isActive])
}

// ============================================================================
// BLOG SYSTEM
// ============================================================================

model BlogAuthor {
  id            Int     @id @default(autoincrement())
  name          String
  nameAr        String?
  avatar        String?
  bio           String? @db.Text
  bioAr         String? @db.Text
  twitterHandle String?

  posts BlogPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model BlogCategory {
  id    Int     @id @default(autoincrement())
  slug  String  @unique
  color String?
  icon  String?

  translations BlogCategoryTranslation[]
  posts        BlogPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model BlogCategoryTranslation {
  id          Int    @id @default(autoincrement())
  categoryId  Int
  locale      Locale

  name        String
  description String? @db.Text

  category BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@index([locale])
}

model BlogTag {
  id   Int    @id @default(autoincrement())
  slug String @unique

  translations BlogTagTranslation[]
  posts        BlogPostTag[]

  createdAt DateTime @default(now())

  @@index([slug])
}

model BlogTagTranslation {
  id     Int    @id @default(autoincrement())
  tagId  Int
  locale Locale

  name String

  tag BlogTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, locale])
  @@index([locale])
}

model BlogPost {
  id            Int              @id @default(autoincrement())
  slug          String           @unique
  featuredImage String?

  isFeatured  Boolean    @default(false)
  status      BlogStatus @default(DRAFT)
  publishedAt DateTime?

  contentType   BlogContentType @default(GUIDE)
  searchIntent  SearchIntent    @default(INFORMATIONAL)
  readingTime   Int?
  faqJson       String?         @db.Text
  blockLayout   String?         @db.Text  // JSON: ordered list of {type, id} for top-level blocks

  primaryStoreId Int?
  primaryStore   Store? @relation("PrimaryStore", fields: [primaryStoreId], references: [id], onDelete: SetNull)

  authorId   Int?
  categoryId Int?
  author     BlogAuthor?   @relation(fields: [authorId], references: [id], onDelete: SetNull)
  category   BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  translations     BlogPostTranslation[]
  tags             BlogPostTag[]
  sections         BlogPostSection[]
  linkedStores     BlogPostStore[]
  relatedProducts  BlogPostProduct[]
  relatedPosts     BlogPostRelated[] @relation("PostToRelated")
  relatedTo        BlogPostRelated[] @relation("RelatedToPost")

  // NEW back‑relation for comparison tables
  comparisonTables ComparisonTable[]

  // Section block embeds
  embeddedInSectionBlocks SectionBlock[] @relation("SectionEmbeddedPosts")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt])
  @@index([contentType])
  @@index([searchIntent])
  @@index([primaryStoreId])
  @@index([isFeatured])
  @@index([categoryId])
  @@index([authorId])
  @@index([slug])
}

model BlogPostTranslation {
  id     Int    @id @default(autoincrement())
  postId Int
  locale Locale

  title   String
  excerpt String  @db.Text
  content String  @db.Text

  metaTitle       String?
  metaDescription String? @db.Text

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, locale])
  @@index([locale])
}

model BlogPostTag {
  postId Int
  tagId  Int

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model BlogPostProduct {
  postId    Int
  productId Int

  post    BlogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  product StoreProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([postId, productId])
}

model BlogPostRelated {
  postId        Int
  relatedPostId Int
  order         Int @default(0)

  post        BlogPost @relation("PostToRelated", fields: [postId], references: [id], onDelete: Cascade)
  relatedPost BlogPost @relation("RelatedToPost", fields: [relatedPostId], references: [id], onDelete: Cascade)

  @@id([postId, relatedPostId])
  @@index([postId, order])
}

model BlogPostStore {
  postId  Int
  storeId Int
  order   Int @default(0)

  post  BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  store Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([postId, storeId])
  @@index([postId, order])
  @@index([storeId])
}

model BlogPostSection {
  id     Int @id @default(autoincrement())
  postId Int
  order  Int @default(0)

  image String?

  post         BlogPost                    @relation(fields: [postId], references: [id], onDelete: Cascade)
  translations BlogPostSectionTranslation[]
  products     BlogPostSectionProduct[]
  stores       BlogPostSectionStore[]
  sectionBlocks SectionBlock[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, order])
}

model BlogPostSectionTranslation {
  id        Int    @id @default(autoincrement())
  sectionId Int
  locale    Locale

  subtitle String?
  content  String @db.Text

  section BlogPostSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, locale])
  @@index([locale])
}

model BlogPostSectionProduct {
  sectionId Int
  productId Int
  order     Int @default(0)

  section BlogPostSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  product StoreProduct    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([sectionId, productId])
  @@index([sectionId, order])
}

model BlogPostSectionStore {
  sectionId Int
  storeId   Int
  order     Int @default(0)

  section BlogPostSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  store   Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([sectionId, storeId])
  @@index([sectionId, order])
}

// ============================================================================
// LEADERBOARD & STORE INTELLIGENCE
// ============================================================================

model SavingsMethodology {
  id          Int     @id @default(autoincrement())
  version     String  @unique
  description String  @db.Text
  isActive    Boolean @default(false)

  maxSavingsCap       Float @default(75.0)
  bankOfferStackable  Boolean @default(true)
  couponStackable     Boolean @default(true)
  referenceBasketSize Float @default(500.0)
  multiplierExact     Float @default(1.00)
  multiplierVerified  Float @default(1.00)
  multiplierTypical   Float @default(0.80)
  multiplierEstimated Float @default(0.35)

  snapshots StoreSavingsSnapshot[]

  createdAt DateTime @default(now())

  @@index([isActive])
}

model StoreSavingsSnapshot {
  id        Int    @id @default(autoincrement())
  storeId   Int
  categoryId Int?

  maxDirectDiscountPercent Float @default(0)
  maxCouponPercent         Float @default(0)
  maxBankOfferPercent      Float @default(0)

  calculatedMaxSavingsPercent Float
  savingsOverridePercent      Float?
  stackingPath                String?

  rank         Int
  previousRank Int?
  movement     RankMovement @default(NEW)

  weekIdentifier     String
  methodologyId      Int?
  calculatedAt       DateTime @default(now())

  store       Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category    Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  methodology SavingsMethodology? @relation(fields: [methodologyId], references: [id], onDelete: SetNull)

  @@unique([storeId, categoryId, weekIdentifier])
  @@index([weekIdentifier, rank])
  @@index([storeId, weekIdentifier])
  @@index([categoryId, weekIdentifier, rank])
  @@index([movement])
}

model StoreSavingsMetrics {
  id              Int    @id @default(autoincrement())
  storeId         Int
  monthIdentifier String

  averageDiscountPercent    Float @default(0)
  maxStackableSavingsPercent Float @default(0)
  codeSuccessRate           Float @default(0)
  totalActiveOffers         Int   @default(0)
  offerQualityRatio         Float @default(0)

  storeScore      Float @default(0)
  scoreBreakdown  String? @db.Text

  updatedAt DateTime @updatedAt

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, monthIdentifier])
  @@index([storeId, monthIdentifier])
  @@index([monthIdentifier])
}

model StoreUpcomingEvent {
  id              Int            @id @default(autoincrement())
  storeId         Int
  eventName       String
  expectedMonth   String
  confidenceLevel ConfidenceLevel @default(MEDIUM)
  expectedMaxDiscount Float?
  notes           String?        @db.Text

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([expectedMonth])
  @@index([confidenceLevel])
}

model StorePeakSeason {
  id        Int    @id @default(autoincrement())
  storeId   Int
  seasonKey String
  nameEn    String
  nameAr    String

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, seasonKey])
  @@index([storeId])
  @@index([seasonKey])
}

// ============================================================================
// BANK MODELS
// ============================================================================

model Bank {
  id         Int      @id @default(autoincrement())
  slug       String   @unique
  logo       String?
  color      String?
  websiteUrl String?
  type       BankType @default(COMMERCIAL)
  appRating  Float?
  isActive   Boolean  @default(true)

  translations   BankTranslation[]
  cards          BankCard[]
  nicheSnapshots BankNicheSnapshot[]
  otherPromos    OtherPromo[]

  // NEW back‑relation for comparison tables
  comparisonColumns ComparisonTableColumn[]

  // Section block embeds
  embeddedInSectionBlocks SectionBlock[] @relation("SectionEmbeddedBanks")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([type])
}

model BankTranslation {
  id     Int    @id @default(autoincrement())
  bankId Int
  locale Locale

  name        String
  description String? @db.Text

  bank Bank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@unique([bankId, locale])
  @@index([locale])
}

model BankCard {
  id        Int  @id @default(autoincrement())
  bankId    Int

  network   CardNetwork
  tier      CardTier    @default(CLASSIC)
  isIslamic Boolean     @default(false)
  image     String?

  annualFee           Float?
  minSalary           Float?
  foreignTxFeePercent Float?

  loungeAccessPerYear   Int?
  hasTravelInsurance    Boolean @default(false)
  hasPurchaseProtection Boolean @default(false)
  hasApplePay           Boolean @default(true)
  hasGooglePay          Boolean @default(true)
  hasSamsungPay         Boolean @default(false)

  cashbackGeneral    Float?
  cashbackTravel     Float?
  cashbackDining     Float?
  cashbackShopping   Float?
  cashbackFuel       Float?
  cashbackGaming     Float?
  cashbackGroceries  Float?
  cashbackOnline     Float?
  cashbackHealthcare Float?

  maxInstallmentMonths Int?

  bank         Bank                @relation(fields: [bankId], references: [id], onDelete: Cascade)
  translations BankCardTranslation[]
  otherPromos  OtherPromo[]

  // NEW back‑relation for comparison tables
  comparisonColumns ComparisonTableColumn[]

  // Section block embeds
  embeddedInSectionBlocks SectionBlock[] @relation("SectionEmbeddedCards")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bankId])
  @@index([network])
  @@index([tier])
}

model BankCardTranslation {
  id     Int    @id @default(autoincrement())
  cardId Int
  locale Locale

  name        String
  description String? @db.Text
  benefits    String? @db.Text

  card BankCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, locale])
  @@index([locale])
}

model BankNicheSnapshot {
  id         Int @id @default(autoincrement())
  bankId     Int
  categoryId Int

  weekIdentifier String

  score          Float
  rank           Int
  previousRank   Int?
  movement       RankMovement  @default(NEW)

  scoreBreakdown Json

  bestCardId Int?

  bank     Bank     @relation(fields: [bankId],     references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  calculatedAt DateTime @default(now())

  @@unique([bankId, categoryId, weekIdentifier])
  @@index([categoryId, weekIdentifier, rank])
  @@index([bankId])
}

// ============================================================================
// COMPARISON TABLES (NEW)
// ============================================================================

model ComparisonTable {
  id     Int  @id @default(autoincrement())
  postId Int?
  order  Int  @default(0)

  entityType ComparisonEntityType @default(CUSTOM)

  post BlogPost? @relation(fields: [postId], references: [id], onDelete: SetNull)

  translations ComparisonTableTranslation[]
  columns      ComparisonTableColumn[]
  rows         ComparisonTableRow[]

  // Section block embeds
  embeddedInSectionBlocks SectionBlock[] @relation("SectionEmbeddedTables")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, order])
}

model ComparisonTableTranslation {
  id      Int    @id @default(autoincrement())
  tableId Int
  locale  Locale

  title    String?
  subtitle String? @db.Text

  table ComparisonTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@unique([tableId, locale])
  @@index([locale])
}

model ComparisonTableColumn {
  id      Int @id @default(autoincrement())
  tableId Int
  order   Int @default(0)

  image         String?
  isHighlighted Boolean @default(false)
  ctaUrl        String?

  storeId    Int?
  bankId     Int?
  bankCardId Int?
  voucherId  Int?
  promoId    Int?
  productId  Int?

  table  ComparisonTable @relation(fields: [tableId], references: [id], onDelete: Cascade)

  translations ComparisonTableColumnTranslation[]
  cells        ComparisonTableCell[]

  // Entity relations
  store    Store?        @relation(fields: [storeId],    references: [id], onDelete: SetNull)
  bank     Bank?         @relation(fields: [bankId],     references: [id], onDelete: SetNull)
  bankCard BankCard?     @relation(fields: [bankCardId], references: [id], onDelete: SetNull)
  voucher  Voucher?      @relation(fields: [voucherId],  references: [id], onDelete: SetNull)
  promo    OtherPromo?   @relation(fields: [promoId],    references: [id], onDelete: SetNull)
  product  StoreProduct? @relation(fields: [productId],  references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tableId, order])
  @@index([storeId])
  @@index([bankId])
  @@index([bankCardId])
}

model ComparisonTableColumnTranslation {
  id       Int    @id @default(autoincrement())
  columnId Int
  locale   Locale

  name        String
  description String?
  badge       String?

  column ComparisonTableColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)

  @@unique([columnId, locale])
  @@index([locale])
}

model ComparisonTableRow {
  id      Int @id @default(autoincrement())
  tableId Int
  order   Int @default(0)

  key     String?
  rowType ComparisonRowType @default(TEXT)

  table        ComparisonTable @relation(fields: [tableId], references: [id], onDelete: Cascade)
  translations ComparisonTableRowTranslation[]
  cells        ComparisonTableCell[]

  @@index([tableId, order])
}

model ComparisonTableRowTranslation {
  id     Int    @id @default(autoincrement())
  rowId  Int
  locale Locale

  label    String
  helpText String?

  row ComparisonTableRow @relation(fields: [rowId], references: [id], onDelete: Cascade)

  @@unique([rowId, locale])
  @@index([locale])
}

model ComparisonTableCell {
  id       Int @id @default(autoincrement())
  columnId Int
  rowId    Int

  textValueEn  String?
  textValueAr  String?
  numericValue Float?
  boolValue    Boolean?

  isHighlighted Boolean @default(false)

  column ComparisonTableColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  row    ComparisonTableRow    @relation(fields: [rowId],    references: [id], onDelete: Cascade)

  @@unique([columnId, rowId])
  @@index([columnId])
  @@index([rowId])
}

// ============================================================================
// SECTION BLOCKS
// ============================================================================

model SectionBlock {
  id        Int             @id @default(autoincrement())
  sectionId Int
  type      SectionBlockType
  order     Int             @default(0)

  // Populated when type = TEXT
  textEn String? @db.Text
  textAr String? @db.Text

  // Entity references — at most one populated per block
  postId    Int?
  tableId   Int?
  productId Int?
  storeId   Int?
  bankId    Int?
  cardId    Int?

  section BlogPostSection  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  post    BlogPost?        @relation("SectionEmbeddedPosts",    fields: [postId],    references: [id], onDelete: SetNull)
  table   ComparisonTable? @relation("SectionEmbeddedTables",   fields: [tableId],   references: [id], onDelete: SetNull)
  product StoreProduct?    @relation("SectionEmbeddedProducts", fields: [productId], references: [id], onDelete: SetNull)
  store   Store?           @relation("SectionEmbeddedStores",   fields: [storeId],   references: [id], onDelete: SetNull)
  bank    Bank?            @relation("SectionEmbeddedBanks",    fields: [bankId],    references: [id], onDelete: SetNull)
  card    BankCard?        @relation("SectionEmbeddedCards",    fields: [cardId],    references: [id], onDelete: SetNull)

  @@index([sectionId, order])
  @@index([type])
}

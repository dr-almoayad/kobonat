// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// ENUMS
// ============================================================================

enum Locale {
  ar
  en
}

// REMOVED Currency enum to avoid migration issues

enum ShowOfferType {
  CODE
  DEAL
  DISCOUNT
  FREE_SHIPPING  // Changed from FREE_DELIVERY
  CASHBACK
  OFFER
}

enum VoucherType {
  CODE           // Requires coupon code
  DEAL           // Auto-applied deal
  FREE_SHIPPING  // Free shipping offer
}

enum PromoType {
  BANK_OFFER      // "15% off with SABB"
  CARD_OFFER      // "Extra 10% with Visa"
  PAYMENT_OFFER   // "5% cashback via STC Pay"
  SEASONAL        // "Ramadan Special"
  BUNDLE          // "Buy 2 Get 1 Free"
  OTHER
}

enum DiscountType {
  PERCENTAGE
  ABSOLUTE
}

enum CuratedOfferType {
  CODE           // Requires coupon code
  DEAL           // Auto-applied deal
  PRODUCT        // Specific product discount
  SEASONAL       // Seasonal offer (Ramadan, Black Friday, etc)
  FREE_SHIPPING  // Free shipping offer
  CASHBACK       // Cashback reward
  BUNDLE         // Buy X Get Y
  FLASH_SALE     // Limited time flash sale
}

enum PaymentType {
  CARD
  BNPL
  COD
  WALLET
  BANK_TRANSFER
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

// ─── NEW: Blog status lifecycle ───────────────────────────────────────────────
enum BlogStatus {
  DRAFT      // Being written, not visible publicly
  PUBLISHED  // Live and visible
  ARCHIVED   // Hidden but preserved
}

// ─── NEW: Content type — drives template selection and structured data ─────────
enum BlogContentType {
  GUIDE        // How-to, tips — informational evergreen
  DEAL_HUB     // Aggregated deals page for one merchant or category
  SEASONAL     // Ramadan, Black Friday, Back to School, etc.
  COMPARISON   // Store A vs Store B, product comparisons
  NEWS         // Time-sensitive announcements
}

// ─── NEW: Search intent — used for internal link strategy + schema.org type ───
enum SearchIntent {
  INFORMATIONAL   // "how to save money on noon"
  COMMERCIAL      // "best noon deals right now"
  TRANSACTIONAL   // "noon coupon code"
}

// ============================================================================
// CORE MODELS
// ============================================================================

model Country {
  id        Int      @id @default(autoincrement())
  code      String   @unique // SA, EG, AE
  currency  String   // SAR, EGP, AED - KEPT AS STRING to avoid migration
  flag      String?  // 🇸🇦
  isActive  Boolean  @default(true)
  isDefault Boolean  @default(false)

  translations        CountryTranslation[]
  stores              StoreCountry[]
  vouchers            VoucherCountry[]
  faqs                StoreFAQ[]
  storePayments       StorePaymentMethod[]
  voucherClicks       VoucherClick[]
  storeProductClicks  StoreProductClick[]
  otherPromos         OtherPromo[]
  curatedOffers       CuratedOfferCountry[]
  storeProducts       StoreProductCountry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model CountryTranslation {
  id        Int    @id @default(autoincrement())
  countryId Int
  locale    Locale

  name String

  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([countryId, locale])
  @@index([locale])
}

// ============================================================================
// STORE - ENHANCED WITH COVER IMAGE
// ============================================================================

model Store {
  id Int @id @default(autoincrement())

  // Images
  logo            String?
  bigLogo         String?
  backgroundImage String?
  coverImage      String? // Hero banner for store page
  color           String? // Brand color for UI theming

  showOfferType ShowOfferType?

  // URLs
  websiteUrl       String
  affiliateNetwork String?
  trackingUrl      String?

  // Status
  isActive   Boolean @default(true)
  isFeatured Boolean @default(false)

  // Relations
  translations   StoreTranslation[]
  countries      StoreCountry[]
  vouchers       Voucher[]
  categories     StoreCategory[]
  faqs           StoreFAQ[]
  paymentMethods StorePaymentMethod[]
  otherPromos    OtherPromo[]
  products       StoreProduct[]
  curatedOffers  CuratedOffer[]
  // Blog relations
  primaryBlogPosts    BlogPost[]         @relation("PrimaryStore")
  blogPostStores      BlogPostStore[]
  blogSectionStores   BlogPostSectionStore[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([isFeatured])
  @@index([showOfferType])
}

model StoreTranslation {
  id      Int    @id @default(autoincrement())
  storeId Int
  locale  Locale

  name        String
  slug        String
  description String? @db.Text

  // SEO
  seoTitle       String?
  seoDescription String? @db.Text

  showOffer String? // "Get 15% off all orders" / "خصم 15% على جميع الطلبات"

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, locale])
  @@unique([locale, slug])
  @@index([locale])
  @@index([slug])
}

// ============================================================================
// CATEGORY - ENHANCED WITH IMAGE
// ============================================================================

model Category {
  id    Int     @id @default(autoincrement())
  icon  String? // Material icon name (e.g., "checkroom", "devices")
  image String? // Category banner/thumbnail
  color String? // Category accent color

  translations CategoryTranslation[]
  stores       StoreCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([color])
}

model CategoryTranslation {
  id         Int    @id @default(autoincrement())
  categoryId Int
  locale     Locale

  name        String
  slug        String
  description String? @db.Text

  seoTitle       String?
  seoDescription String? @db.Text

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@unique([locale, slug])
  @@index([locale])
  @@index([slug])
}

// ============================================================================
// VOUCHER - COUPONS & DEALS
// ============================================================================

model Voucher {
  id      Int @id @default(autoincrement())
  storeId Int

  // Voucher Details
  code     String?     // Coupon code (e.g., "SAVE20")
  type     VoucherType
  discount String?     // "20%", "50 SAR off", "Buy 1 Get 1"

  // Image for featured deals
  image String? // Hero image for visual deals

  // Links
  landingUrl String? // Direct product/deal URL

  // Validity
  startDate  DateTime?
  expiryDate DateTime?

  // Badges
  isExclusive Boolean @default(false)
  isVerified  Boolean @default(false)

  // Analytics
  popularityScore Int @default(0)
  clickCount      Int @default(0)

  // Relations
  translations VoucherTranslation[]
  countries    VoucherCountry[]
  store        Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  clicks       VoucherClick[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([expiryDate])
  @@index([isExclusive])
  @@index([isVerified])
  @@index([popularityScore])
  @@index([clickCount])
  @@index([type])
}

model VoucherTranslation {
  id        Int    @id @default(autoincrement())
  voucherId Int
  locale    Locale

  title       String        // "20% Off Everything"
  description String? @db.Text // "Valid on all items. Min spend 200 SAR"

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)

  @@unique([voucherId, locale])
  @@index([locale])
}

// ============================================================================
// STORE PRODUCTS - FEATURED ITEMS
// ============================================================================

model StoreProduct {
  id      Int @id @default(autoincrement())
  storeId Int

  // Product Details
  image        String       // Product image (required)
  discountValue Float?       // Discount amount (percentage or absolute)
  discountType  DiscountType @default(PERCENTAGE)

  // Links
  productUrl String // Direct link to product on store website

  // Display
  isFeatured Boolean @default(true) // Show on store page
  order      Int     @default(0)    // Display order

  // Analytics
  clickCount Int @default(0)

  // Relations
  translations StoreProductTranslation[]
  store        Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  clicks       StoreProductClick[]
  countries    StoreProductCountry[]
  blogProducts BlogPostProduct[]        // post-level product links
  blogSectionProducts BlogPostSectionProduct[] // section-level product links

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([isFeatured])
  @@index([order])
  @@index([discountType])
}

model StoreProductTranslation {
  id        Int    @id @default(autoincrement())
  productId Int
  locale    Locale

  title       String        // Changed from optional to required
  description String? @db.Text

  product StoreProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@index([locale])
}

model StoreProductClick {
  id        Int  @id @default(autoincrement())
  productId Int
  countryId Int?

  ipHash    String?
  userAgent String?
  referrer  String?
  clickedAt DateTime @default(now())

  product StoreProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  country Country?     @relation(fields: [countryId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([clickedAt])
  @@index([countryId])
}

// ============================================================================
// OTHER PROMOS - BANK/CARD OFFERS
// ============================================================================

model OtherPromo {
  id        Int @id @default(autoincrement())
  storeId   Int
  countryId Int

  // Promo Details
  image String?    // Banner image
  type  PromoType

  // Links
  url String? // External link to T&Cs or signup

  // Validity
  startDate  DateTime?
  expiryDate DateTime?

  isActive Boolean @default(true)
  order    Int     @default(0)

  // Relations
  translations OtherPromoTranslation[]
  store        Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  country      Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId, countryId])
  @@index([isActive])
  @@index([expiryDate])
  @@index([order])
  @@index([type])
}

model OtherPromoTranslation {
  id      Int    @id @default(autoincrement())
  promoId Int
  locale  Locale

  title       String        // "10% Cashback with Visa"
  description String? @db.Text
  terms       String? @db.Text

  promo OtherPromo @relation(fields: [promoId], references: [id], onDelete: Cascade)

  @@unique([promoId, locale])
  @@index([locale])
}

// ============================================================================
// CURATED OFFERS - ENHANCED WITH COUNTRY RELATION
// ============================================================================

model CuratedOffer {
  id      Int @id @default(autoincrement())
  storeId Int

  // Offer Details
  offerImage String           // Squircle image URL
  code       String?          // Optional coupon code
  type       CuratedOfferType

  // CTA
  ctaUrl String // Where clicking leads

  // Validity
  startDate  DateTime?
  expiryDate DateTime?

  // Display
  isFeatured Boolean @default(false)
  isActive   Boolean @default(true)
  order      Int     @default(0)

  // Relations
  translations CuratedOfferTranslation[]
  store        Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  countries    CuratedOfferCountry[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([storeId])
  @@index([isFeatured])
  @@index([isActive])
  @@index([expiryDate])
  @@index([type])
  @@index([order])
}

model CuratedOfferTranslation {
  id      Int    @id @default(autoincrement())
  offerId Int
  locale  Locale

  title       String        // "€25 BYOD Plan!"
  description String? @db.Text
  ctaText     String        // "SHOP NOW", "GET OFFER"

  offer CuratedOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@unique([offerId, locale])
  @@index([locale])
}

// ============================================================================
// PAYMENT METHODS
// ============================================================================

model PaymentMethod {
  id     Int         @id @default(autoincrement())
  slug   String      @unique
  type   PaymentType
  isBnpl Boolean     @default(false)
  logo   String?

  translations PaymentMethodTranslation[]
  storeLinks   StorePaymentMethod[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@index([isBnpl])
  @@index([slug])
}

model PaymentMethodTranslation {
  id              Int    @id @default(autoincrement())
  paymentMethodId Int
  locale          Locale

  name        String
  description String? @db.Text

  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)

  @@unique([paymentMethodId, locale])
  @@index([locale])
}

model StorePaymentMethod {
  id              Int @id @default(autoincrement())
  storeId         Int
  countryId       Int
  paymentMethodId Int

  isActive  Boolean @default(true)
  minAmount Float?
  maxAmount Float?

  store         Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  country       Country       @relation(fields: [countryId], references: [id], onDelete: Cascade)
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id], onDelete: Cascade)
  translations  StorePaymentMethodTranslation[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, countryId, paymentMethodId])
  @@index([storeId, countryId])
  @@index([isActive])
}

model StorePaymentMethodTranslation {
  id                   Int    @id @default(autoincrement())
  storePaymentMethodId Int
  locale               Locale

  notes String? @db.Text

  storePaymentMethod StorePaymentMethod @relation(fields: [storePaymentMethodId], references: [id], onDelete: Cascade)

  @@unique([storePaymentMethodId, locale])
  @@index([locale])
}

// ============================================================================
// STORE FAQ
// ============================================================================

model StoreFAQ {
  id        Int     @id @default(autoincrement())
  storeId   Int
  countryId Int
  order     Int     @default(0)
  isActive  Boolean @default(true)

  translations StoreFAQTranslation[]
  store        Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  country      Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, countryId, order])
  @@index([storeId, countryId])
  @@index([isActive])
  @@index([order])
}

model StoreFAQTranslation {
  id     Int    @id @default(autoincrement())
  faqId  Int
  locale Locale

  question String
  answer   String @db.Text

  faq StoreFAQ @relation(fields: [faqId], references: [id], onDelete: Cascade)

  @@unique([faqId, locale])
  @@index([locale])
}

// ============================================================================
// JUNCTION TABLES
// ============================================================================

model StoreCountry {
  storeId   Int
  countryId Int

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@id([storeId, countryId])
}

model VoucherCountry {
  voucherId Int
  countryId Int

  voucher Voucher @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  country Country @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@id([voucherId, countryId])
}

model StoreCategory {
  storeId    Int
  categoryId Int

  store    Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([storeId, categoryId])
}

model CuratedOfferCountry {
  offerId   Int
  countryId Int

  offer   CuratedOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  country Country      @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@id([offerId, countryId])
}

model StoreProductCountry {
  productId Int
  countryId Int

  product StoreProduct @relation(fields: [productId], references: [id], onDelete: Cascade)
  country Country      @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@id([productId, countryId])
}

// ============================================================================
// ANALYTICS
// ============================================================================

model VoucherClick {
  id        Int  @id @default(autoincrement())
  voucherId Int
  countryId Int?

  ipHash    String?
  userAgent String?
  referrer  String?
  clickedAt DateTime @default(now())

  voucher Voucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  country Country? @relation(fields: [countryId], references: [id], onDelete: SetNull)

  @@index([voucherId])
  @@index([clickedAt])
  @@index([countryId])
}

// ============================================================================
// ADMIN
// ============================================================================

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  password     String
  role         AdminRole @default(ADMIN)
  permissions  String[]
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  resetToken   String?
  resetExpires DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([isActive])
}

// ============================================================================
// BLOG SYSTEM
// ============================================================================

// ── Author ───────────────────────────────────────────────────────────────────
// Separate from Admin because authors may not have login access, and their
// public profile (bio, avatar, social) belongs on the frontend, not in Admin.

model BlogAuthor {
  id            Int     @id @default(autoincrement())
  name          String  // Display name in English
  nameAr        String? // Display name in Arabic
  avatar        String? // URL to profile photo
  bio           String? @db.Text // Short bio in English
  bioAr         String? @db.Text // Short bio in Arabic
  twitterHandle String? // Without @, used for schema.org sameAs

  posts BlogPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

// ── Blog Category ─────────────────────────────────────────────────────────────
// Stores have a Category model; blogs get their own to avoid cross-contamination
// of slugs and translations between store categories and content categories.

model BlogCategory {
  id    Int     @id @default(autoincrement())
  slug  String  @unique // e.g. "shopping-tips" — shared across locales
  color String? // Accent color for UI badges
  icon  String? // Optional icon name

  translations BlogCategoryTranslation[]
  posts        BlogPost[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model BlogCategoryTranslation {
  id          Int    @id @default(autoincrement())
  categoryId  Int
  locale      Locale // Uses existing Locale enum (ar | en)

  name        String
  description String? @db.Text

  category BlogCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@unique([categoryId, locale])
  @@index([locale])
}

// ── Blog Tag ──────────────────────────────────────────────────────────────────
// Tags are flat (no hierarchy), many-to-many with posts.
// Slug is the stable identifier; names are translated.

model BlogTag {
  id   Int    @id @default(autoincrement())
  slug String @unique // e.g. "noon", "electronics"

  translations BlogTagTranslation[]
  posts        BlogPostTag[]

  createdAt DateTime @default(now())

  @@index([slug])
}

model BlogTagTranslation {
  id     Int    @id @default(autoincrement())
  tagId  Int
  locale Locale

  name String // e.g. "Electronics" / "إلكترونيات"

  tag BlogTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([tagId, locale])
  @@index([locale])
}

// ── Blog Post ─────────────────────────────────────────────────────────────────
// Core content record. Slug is language-agnostic (always English).
// URL pattern: /ar-SA/blog/slug and /en-SA/blog/slug.

model BlogPost {
  id            Int              @id @default(autoincrement())
  slug          String           @unique
  featuredImage String?

  // ── Status & visibility ───────────────────────────────────────────────────
  isFeatured  Boolean    @default(false)
  status      BlogStatus @default(DRAFT)
  publishedAt DateTime?

  // ── SEO strategy fields ───────────────────────────────────────────────────
  contentType   BlogContentType @default(GUIDE)
  searchIntent  SearchIntent    @default(INFORMATIONAL)
  readingTime   Int?            // minutes, computed from content word count
  faqJson       String?         @db.Text // JSON array: [{q, a}, ...] for FAQ schema.org

  // ── Merchant clustering ───────────────────────────────────────────────────
  // One post belongs to one primary store. Used to:
  // - auto-surface this post on the store's page
  // - build topical authority clusters per merchant
  primaryStoreId Int?
  primaryStore   Store? @relation("PrimaryStore", fields: [primaryStoreId], references: [id], onDelete: SetNull)

  // ── Taxonomy ──────────────────────────────────────────────────────────────
  authorId   Int?
  categoryId Int?
  author     BlogAuthor?   @relation(fields: [authorId], references: [id], onDelete: SetNull)
  category   BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  // ── Relations ─────────────────────────────────────────────────────────────
  translations     BlogPostTranslation[]
  tags             BlogPostTag[]
  sections         BlogPostSection[]     // structured content blocks
  linkedStores     BlogPostStore[]       // explicit post-level store links
  relatedProducts  BlogPostProduct[]     // post-level product links
  relatedPosts     BlogPostRelated[] @relation("PostToRelated")
  relatedTo        BlogPostRelated[] @relation("RelatedToPost")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, publishedAt])  // primary list query
  @@index([contentType])          // filter by content type
  @@index([searchIntent])         // filter by intent
  @@index([primaryStoreId])       // store page cluster query
  @@index([isFeatured])
  @@index([categoryId])
  @@index([authorId])
  @@index([slug])
}

// ── Blog Post Translation ─────────────────────────────────────────────────────
// All text content is per-locale. Meta fields fall back to title/excerpt
// if left blank (handled in application layer, not schema).

model BlogPostTranslation {
  id     Int    @id @default(autoincrement())
  postId Int
  locale Locale // Uses existing Locale enum (ar | en)

  // Core content
  title   String
  excerpt String  @db.Text // Short summary for cards and meta
  content String  @db.Text // Full HTML/rich text body

  // SEO overrides (optional — fall back to title/excerpt if null)
  metaTitle       String?
  metaDescription String? @db.Text

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, locale])
  @@index([locale])
}

// ── Junction: Post ↔ Tag ──────────────────────────────────────────────────────

model BlogPostTag {
  postId Int
  tagId  Int

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  BlogTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

// ── Junction: Post ↔ StoreProduct ─────────────────────────────────────────────
// Links blog posts to specific store products for internal SEO linking.
// Uses a proper FK to StoreProduct (not bare Int) for referential integrity.

model BlogPostProduct {
  postId    Int
  productId Int

  post    BlogPost     @relation(fields: [postId], references: [id], onDelete: Cascade)
  product StoreProduct @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([postId, productId])
}

// ── Self-join: Related Posts ───────────────────────────────────────────────────
// Explicit editorial overrides for "Related Articles" sections.
// When set, these take priority over algorithmic tag/category matching.
// Named relations ("PostToRelated" / "RelatedToPost") are required by
// Prisma whenever a model has two relations pointing to the same model.

model BlogPostRelated {
  postId        Int
  relatedPostId Int
  order         Int @default(0) // Controls display sequence

  post        BlogPost @relation("PostToRelated", fields: [postId], references: [id], onDelete: Cascade)
  relatedPost BlogPost @relation("RelatedToPost", fields: [relatedPostId], references: [id], onDelete: Cascade)

  @@id([postId, relatedPostId])
  @@index([postId, order]) // Ordered fetch of a post's related articles
}

// ── Junction: Post ↔ Store (post-level explicit links) ────────────────────────
// Used to display "Stores mentioned in this article" at the bottom of a post.
// Also used to build the reverse relation: which posts mention a given store.
// order controls display sequence in the UI.

model BlogPostStore {
  postId  Int
  storeId Int
  order   Int @default(0)

  post  BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  store Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([postId, storeId])
  @@index([postId, order])
  @@index([storeId])         // reverse: all posts that mention this store
}

// ── Section-based content architecture ───────────────────────────────────────
// Each BlogPost is composed of ordered sections instead of one monolithic
// content field. This enables:
//   - Per-section product recommendations
//   - Per-section store callouts
//   - Section-level images (e.g. step screenshots, product shots)
//   - Easier CMS editing in the admin panel
//
// The BlogPostTranslation.content field is kept for backwards compatibility
// and can serve as a fallback / legacy field.

model BlogPostSection {
  id     Int @id @default(autoincrement())
  postId Int
  order  Int @default(0)  // controls display sequence within a post

  // Optional section-level image (e.g. step diagram, product banner)
  image String?

  // Relations
  post         BlogPost                    @relation(fields: [postId], references: [id], onDelete: Cascade)
  translations BlogPostSectionTranslation[]
  products     BlogPostSectionProduct[]
  stores       BlogPostSectionStore[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([postId, order])  // primary fetch: all sections for a post in order
}

// ── Section translation ───────────────────────────────────────────────────────
// subtitle and content are per-locale. subtitle renders as an <h3> inside
// the article. content is HTML/rich text for the section body.

model BlogPostSectionTranslation {
  id        Int    @id @default(autoincrement())
  sectionId Int
  locale    Locale

  subtitle String?        // Optional section heading (h3)
  content  String @db.Text // Section body — HTML/rich text

  section BlogPostSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@unique([sectionId, locale])
  @@index([locale])
}

// ── Junction: Section ↔ StoreProduct ─────────────────────────────────────────
// Links individual products into a specific section of a post.
// e.g. "Best Noon Electronics Deals" section → specific product cards
// order controls the display sequence of products within the section.

model BlogPostSectionProduct {
  sectionId Int
  productId Int
  order     Int @default(0)

  section BlogPostSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  product StoreProduct    @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([sectionId, productId])
  @@index([sectionId, order])
}

// ── Junction: Section ↔ Store ─────────────────────────────────────────────────
// Links stores into a specific section of a post.
// e.g. "Where to buy" section → Noon, Amazon, Jarir callout cards
// order controls display sequence within the section.

model BlogPostSectionStore {
  sectionId Int
  storeId   Int
  order     Int @default(0)

  section BlogPostSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  store   Store           @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@id([sectionId, storeId])
  @@index([sectionId, order])
}
